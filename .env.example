# ─── Supabase (required) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres pooler — needed for migrations + scripts
# Must use Session pooler (port 5432, NOT Transaction pooler 6543).
# Special chars in password must be percent-encoded (@→%40, !→%21).
# DATABASE_URL=postgresql://postgres.<project-ref>:<DB-PASSWORD>@aws-N-<region>.pooler.supabase.com:5432/postgres

# ─── Google APIs ───────────────────────────────────────────────────────
# Google Maps (required — maps + Street View + tier-1 geocoding)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Custom Search (optional — 100 free queries/day for web research)
# Create engine: https://programmablesearchengine.google.com/
# API key: https://console.cloud.google.com/apis/credentials
# GOOGLE_CUSTOM_SEARCH_KEY=your-api-key
# GOOGLE_CUSTOM_SEARCH_CX=your-search-engine-id

# ─── Embrapa AgroAPI ───────────────────────────────────────────────────
# AGROFIT, Bioinsumos, ClimAPI, AgroTermos, SmartSolos
# Get keys at: https://www.agroapi.cnptia.embrapa.br/store/
# AGROAPI_CONSUMER_KEY=your-consumer-key
# AGROAPI_CONSUMER_SECRET=your-consumer-secret

# ─── AI / LLM ─────────────────────────────────────────────────────────
# Vertex AI — auto-detected from agrisafe-*.json SA key file in project root.
# No env vars needed. Get the key file from the team lead.
# See CLAUDE.md → "AI / LLM Provider" for setup + data privacy rationale.
#
# DO NOT use Gemini API free tier — Google uses your prompts to train models.
#
# OpenAI (optional — company research summaries, analysis lenses)
# OPENAI_API_KEY=your-openai-key

# ─── Resend (mailing — briefing fan-out, P3) ───────────────────────────
# Mailing workflow: AI agent drafts → reviewer edits → Resend fan-out per
# (persona × culture). Schema lives in mig 083 (mailing_clients, _drafts, _log).
# Get an API key at: https://resend.com → API Keys → Create API Key
# Domain `agrisafe.agr.br` must be verified in Resend (DKIM/SPF/DMARC in Route 53).
# In Vercel: store as Sensitive type, scope to All Environments.
# RESEND_API_KEY=re_your-resend-api-key
# RESEND_FROM_EMAIL=briefing@agrisafe.agr.br
# RESEND_FROM_NAME=AgriSafe Inteligência
# RESEND_REPLY_TO=contato@agrisafe.agr.br

# ─── Auth / Secrets ────────────────────────────────────────────────────
# Phase 22 — Chrome extension auth (POST /api/reading-room/ingest)
# READING_ROOM_SECRET=your-reading-room-secret

# Cron secret (production cron auth gate)
# CRON_SECRET=your-cron-secret
